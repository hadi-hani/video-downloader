{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/download.py": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/download",
      "dest": "/api/download.py",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
